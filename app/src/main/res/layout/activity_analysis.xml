<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    tools:context=".AnalysisActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 상단 바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E293B"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="15dp">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="20sp"
                android:backgroundTint="#334155"
                android:textColor="#FFFFFF"
                android:minWidth="48dp"
                android:layout_marginEnd="15dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI 예측 분석"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 분석 대상 종목 (intent로 전달받음) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/imgStockLogo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="#1E293B"
                android:scaleType="centerInside"
                android:contentDescription="종목 로고" />

            <TextView
                android:id="@+id/txtStockName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="APPLE INC. (AAPL)"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- 핵심 예측 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E293B"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="15dp"
            android:padding="25dp"
            android:gravity="center"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LSTM 모델 예측 결과"
                android:textColor="#94A3B8"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내일 예측가"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginTop="15dp" />

            <!-- intent로 전달받은 현재가 기반 예측 -->
            <TextView
                android:id="@+id/txtPredictedPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$182.30"
                android:textColor="#F59E0B"
                android:textSize="42sp"
                android:textStyle="bold"
                android:layout_marginTop="5dp" />

            <TextView
                android:id="@+id/txtExpectedReturn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↑ 예상 수익률 +2.13%"
                android:textColor="#10B981"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 현재가 vs 예측가 비교 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="15dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1E293B"
                android:padding="18dp"
                android:gravity="center"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="현재가"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />

                <!-- intent로 전달받은 현재가 -->
                <TextView
                    android:id="@+id/txtCurrentPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$178.50"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="5dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- AI 투자 조언 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E293B"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="15dp"
            android:padding="20dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 Gemini의 투자 조언"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/txtAIAdvice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="현재 APPLE 주식은 긍정적인 추세를 보이고 있습니다. 기술 섹터의 강세와 함께 회사의 실적 개선으로 인해 단기적 상승 가능성이 높습니다. 다만 시장 변동성을 고려하여 분할 매수를 권장하며, 손절 라인은 현재가 대비 -5% 수준으로 설정하는 것이 안전합니다."
                android:textColor="#CBD5E1"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6" />
        </LinearLayout>

        <!-- 투자 위험도 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E293B"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="15dp"
            android:padding="20dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="투자 위험도"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="중간"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="#F59E0B"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 카카오톡 공유 버튼 -->
        <Button
            android:id="@+id/btnShare"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💬 카카오톡으로 공유하기"
            android:backgroundTint="#FFE812"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="30dp" />

    </LinearLayout>
</ScrollView>